{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build GTK Program",
            "type": "shell",
            "command": "gcc",
            "args": [
                "F:/GTK_PROJECT/hello.c",
                "-o",
                "F:/GTK_PROJECT/hello.exe",
                "`pkg-config --cflags --libs gtk4`"
            ],
            "options": {
                "shell": {
                    "executable": "C:/msys64/usr/bin/bash.exe",
                    "args": ["-l"]
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}
